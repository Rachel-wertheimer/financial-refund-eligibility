{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "Server=${DB_SERVER};Database=${RefundSystemDb};Trusted_Connection=True;TrustServerCertificate=True;"
  },

  "Jwt": {
    "Key": "CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY_1234567890",
    "Issuer": "RefundSystem",
    "Audience": "RefundSystemClients",
    "ExpiresMinutes": 60
  },

  "AllowedHosts": "*"
}
